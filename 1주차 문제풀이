#1

score = int(input("점수 : "))

if 96<= score <= 100 :
    print('A+')
elif 91<= score < 96:
    print('A')
elif 86<= score <91 :
    print('B+')
elif 81<= score <86:
    print('B')
elif 76<= score <81:
    print('C+')
elif 71<= score <76:
    print('C')
elif 66<= score <71:
    print('D+')
elif 61<= score <66:
    print('D')
elif 0<= score <61:
    print('F')
else:
    print('입력값이 올바르지 않습니다.')
 
   
