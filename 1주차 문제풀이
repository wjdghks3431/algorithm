    for n in range(1,10) :
        print(f'{i+3} * {n}={(i+3)*n} {i+4} * {n}={(i+4)*n} {i+5} * {n}={(i+5)*n}')
    for n in range(1,10) :
        print(f'{i+6} * {n}={(i+6)*n} {i+7} * {n}={(i+7)*n} {i+8} * {n}={(i+8)*n}')



